APP_ENV=development
LOG_LEVEL=info
HTTP_ADDR=:8080
SHUTDOWN_TIMEOUT=10s

DB_DRIVER=sqlite
DB_DSN=locator.db
DB_AUTO_MIGRATE=true
DB_MAX_IDLE_CONNS=5
DB_MAX_OPEN_CONNS=20
DB_CONN_MAX_IDLE_TIME=5m
DB_CONN_MAX_LIFETIME=30m
# PostgreSQL example:
# DB_DRIVER=postgres
# DB_DSN=host=127.0.0.1 user=postgres password=postgres dbname=locator port=5432 sslmode=disable TimeZone=UTC

MQTT_ENABLED=false
MQTT_BROKER=tcp://127.0.0.1:1883
MQTT_CLIENT_ID=locator-backend
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPICS=device/+/gps,device/+/status,device/+/alarm
MQTT_QOS=1
MQTT_CONNECT_TIMEOUT=10s
MQTT_OPERATION_TIMEOUT=5s
